---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Energy / Pressure / Angle Converter — Oriz Universal Converter" description="Convert energy (J, cal, kWh), pressure (Pa, bar, psi), and angles (deg, rad, grad) — all in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">energy / pressure / angle</h1>
    <p class="status mono ready">ready · v1</p>

    <h2 class="section-title">Energy</h2>
    <div class="converter">
      <div class="row">
        <label for="j">Joules (J)</label>
        <input id="j" class="energy-input" type="number" step="any" placeholder="0" data-unit="j" />
      </div>
      <div class="row">
        <label for="kj">Kilojoules (kJ)</label>
        <input id="kj" class="energy-input" type="number" step="any" placeholder="0" data-unit="kj" />
      </div>
      <div class="row">
        <label for="cal">Calories (cal)</label>
        <input id="cal" class="energy-input" type="number" step="any" placeholder="0" data-unit="cal" />
      </div>
      <div class="row">
        <label for="kcal">Kilocalories (kcal)</label>
        <input id="kcal" class="energy-input" type="number" step="any" placeholder="0" data-unit="kcal" />
      </div>
      <div class="row">
        <label for="kwh">Kilowatt-hours (kWh)</label>
        <input id="kwh" class="energy-input" type="number" step="any" placeholder="0" data-unit="kwh" />
      </div>
      <div class="row">
        <label for="btu">BTU</label>
        <input id="btu" class="energy-input" type="number" step="any" placeholder="0" data-unit="btu" />
      </div>
    </div>
    <button class="reset-btn" id="reset-e">Reset energy</button>

    <h2 class="section-title" style="margin-top:2.5rem">Pressure</h2>
    <div class="converter">
      <div class="row">
        <label for="pa">Pascals (Pa)</label>
        <input id="pa" class="pressure-input" type="number" step="any" placeholder="0" data-unit="pa" />
      </div>
      <div class="row">
        <label for="kpa">Kilopascals (kPa)</label>
        <input id="kpa" class="pressure-input" type="number" step="any" placeholder="0" data-unit="kpa" />
      </div>
      <div class="row">
        <label for="bar">Bar</label>
        <input id="bar" class="pressure-input" type="number" step="any" placeholder="0" data-unit="bar" />
      </div>
      <div class="row">
        <label for="psi">PSI (lb/in²)</label>
        <input id="psi" class="pressure-input" type="number" step="any" placeholder="0" data-unit="psi" />
      </div>
      <div class="row">
        <label for="atm">Atmospheres (atm)</label>
        <input id="atm" class="pressure-input" type="number" step="any" placeholder="0" data-unit="atm" />
      </div>
      <div class="row">
        <label for="mmhg">mmHg (Torr)</label>
        <input id="mmhg" class="pressure-input" type="number" step="any" placeholder="0" data-unit="mmhg" />
      </div>
    </div>
    <button class="reset-btn" id="reset-p">Reset pressure</button>

    <h2 class="section-title" style="margin-top:2.5rem">Angle</h2>
    <div class="converter">
      <div class="row">
        <label for="deg">Degrees (°)</label>
        <input id="deg" class="angle-input" type="number" step="any" placeholder="0" data-unit="deg" />
      </div>
      <div class="row">
        <label for="rad">Radians (rad)</label>
        <input id="rad" class="angle-input" type="number" step="any" placeholder="0" data-unit="rad" />
      </div>
      <div class="row">
        <label for="grad">Gradians (grad)</label>
        <input id="grad" class="angle-input" type="number" step="any" placeholder="0" data-unit="grad" />
      </div>
      <div class="row">
        <label for="turn">Turns</label>
        <input id="turn" class="angle-input" type="number" step="any" placeholder="0" data-unit="turn" />
      </div>
    </div>
    <button class="reset-btn" id="reset-a">Reset angle</button>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .section-title { font-family: var(--font-display); font-size: 1rem; font-weight: 600; color: var(--muted); letter-spacing: 0.04em; text-transform: uppercase; margin: 0 0 1rem; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .converter { display: grid; gap: 0.75rem; max-width: 36rem; margin-bottom: 1rem; }
  .row { display: grid; grid-template-columns: 14rem 1fr; align-items: center; gap: 1rem; }
  label { font-size: 0.9375rem; color: var(--muted); font-family: var(--font-mono); }
  input[type="number"] {
    padding: 0.6rem 0.875rem;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 1rem;
    width: 100%;
    outline: none;
    transition: border-color 120ms;
  }
  input[type="number"]:focus { border-color: var(--accent); }
  .reset-btn {
    padding: 0.5rem 1.25rem;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    cursor: pointer;
    letter-spacing: 0.06em;
    transition: color 120ms, border-color 120ms;
  }
  .reset-btn:hover { color: var(--ink); border-color: var(--ink); }
  @media (max-width: 540px) { .row { grid-template-columns: 1fr; gap: 0.25rem; } }
</style>

<script>
  function fmt(n: number): string {
    if (!isFinite(n)) return ''
    return parseFloat(n.toPrecision(10)).toString()
  }

  function wire(selector: string, baseFactors: Record<string, number>) {
    const inputs = document.querySelectorAll<HTMLInputElement>(selector)
    inputs.forEach(input => {
      input.addEventListener('input', () => {
        const raw = input.value.trim()
        if (raw === '' || raw === '-') {
          inputs.forEach(i => { if (i !== input) i.value = '' })
          return
        }
        const val = parseFloat(raw)
        if (isNaN(val)) return
        const unit = input.dataset.unit!
        const base = val * baseFactors[unit]
        inputs.forEach(i => {
          if (i === input) return
          i.value = fmt(base / baseFactors[i.dataset.unit!])
        })
      })
    })
  }

  // Energy: joules per unit
  wire('.energy-input', {
    j:    1,
    kj:   1000,
    cal:  4.184,
    kcal: 4184,
    kwh:  3600000,
    btu:  1055.05585262,
  })

  // Pressure: pascals per unit
  wire('.pressure-input', {
    pa:   1,
    kpa:  1000,
    bar:  100000,
    psi:  6894.757293168,
    atm:  101325,
    mmhg: 133.322387415,
  })

  // Angle: degrees per unit
  wire('.angle-input', {
    deg:  1,
    rad:  180 / Math.PI,
    grad: 0.9,
    turn: 360,
  })

  document.getElementById('reset-e')!.addEventListener('click', () => {
    document.querySelectorAll<HTMLInputElement>('.energy-input').forEach(i => { i.value = '' })
  })
  document.getElementById('reset-p')!.addEventListener('click', () => {
    document.querySelectorAll<HTMLInputElement>('.pressure-input').forEach(i => { i.value = '' })
  })
  document.getElementById('reset-a')!.addEventListener('click', () => {
    document.querySelectorAll<HTMLInputElement>('.angle-input').forEach(i => { i.value = '' })
  })
</script>
