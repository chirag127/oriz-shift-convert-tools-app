---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Data Size Converter (B / KB / MB / GB / TB) — Oriz Universal Converter" description="Convert between bytes, kilobytes, megabytes, gigabytes, terabytes — all in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">data size converter</h1>
    <p class="status mono ready">ready · v1</p>

    <h2 class="section-title">SI (decimal, powers of 10)</h2>
    <div class="converter">
      <div class="row">
        <label for="bit">Bits (bit)</label>
        <input id="bit" class="num-input" type="number" step="any" placeholder="0" data-unit="bit" />
      </div>
      <div class="row">
        <label for="b">Bytes (B)</label>
        <input id="b" class="num-input" type="number" step="any" placeholder="0" data-unit="b" />
      </div>
      <div class="row">
        <label for="kb">Kilobytes (KB)</label>
        <input id="kb" class="num-input" type="number" step="any" placeholder="0" data-unit="kb" />
      </div>
      <div class="row">
        <label for="mb">Megabytes (MB)</label>
        <input id="mb" class="num-input" type="number" step="any" placeholder="0" data-unit="mb" />
      </div>
      <div class="row">
        <label for="gb">Gigabytes (GB)</label>
        <input id="gb" class="num-input" type="number" step="any" placeholder="0" data-unit="gb" />
      </div>
      <div class="row">
        <label for="tb">Terabytes (TB)</label>
        <input id="tb" class="num-input" type="number" step="any" placeholder="0" data-unit="tb" />
      </div>
      <div class="row">
        <label for="pb">Petabytes (PB)</label>
        <input id="pb" class="num-input" type="number" step="any" placeholder="0" data-unit="pb" />
      </div>
    </div>
    <button class="reset-btn" id="reset-si">Reset SI</button>

    <h2 class="section-title" style="margin-top:2.5rem">IEC (binary, powers of 2)</h2>
    <div class="converter">
      <div class="row">
        <label for="kib">Kibibytes (KiB)</label>
        <input id="kib" class="num-input iec" type="number" step="any" placeholder="0" data-unit="kib" />
      </div>
      <div class="row">
        <label for="mib">Mebibytes (MiB)</label>
        <input id="mib" class="num-input iec" type="number" step="any" placeholder="0" data-unit="mib" />
      </div>
      <div class="row">
        <label for="gib">Gibibytes (GiB)</label>
        <input id="gib" class="num-input iec" type="number" step="any" placeholder="0" data-unit="gib" />
      </div>
      <div class="row">
        <label for="tib">Tebibytes (TiB)</label>
        <input id="tib" class="num-input iec" type="number" step="any" placeholder="0" data-unit="tib" />
      </div>
    </div>
    <button class="reset-btn" id="reset-iec">Reset IEC</button>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .section-title { font-family: var(--font-display); font-size: 1rem; font-weight: 600; color: var(--muted); letter-spacing: 0.04em; text-transform: uppercase; margin: 0 0 1rem; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .converter { display: grid; gap: 0.75rem; max-width: 36rem; margin-bottom: 1rem; }
  .row { display: grid; grid-template-columns: 14rem 1fr; align-items: center; gap: 1rem; }
  label { font-size: 0.9375rem; color: var(--muted); font-family: var(--font-mono); }
  .num-input {
    padding: 0.6rem 0.875rem;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 1rem;
    width: 100%;
    outline: none;
    transition: border-color 120ms;
  }
  .num-input:focus { border-color: var(--accent); }
  .reset-btn {
    padding: 0.5rem 1.25rem;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    cursor: pointer;
    letter-spacing: 0.06em;
    transition: color 120ms, border-color 120ms;
  }
  .reset-btn:hover { color: var(--ink); border-color: var(--ink); }
  @media (max-width: 540px) { .row { grid-template-columns: 1fr; gap: 0.25rem; } }
</style>

<script>
  function fmt(n: number): string {
    if (!isFinite(n)) return ''
    return parseFloat(n.toPrecision(10)).toString()
  }

  function wire(selector: string, baseFactors: Record<string, number>) {
    const inputs = document.querySelectorAll<HTMLInputElement>(selector)
    inputs.forEach(input => {
      input.addEventListener('input', () => {
        const raw = input.value.trim()
        if (raw === '' || raw === '-') {
          inputs.forEach(i => { if (i !== input) i.value = '' })
          return
        }
        const val = parseFloat(raw)
        if (isNaN(val)) return
        const unit = input.dataset.unit!
        const base = val * baseFactors[unit]
        inputs.forEach(i => {
          if (i === input) return
          i.value = fmt(base / baseFactors[i.dataset.unit!])
        })
      })
    })
  }

  // SI — bits per unit
  wire('.num-input:not(.iec)', {
    bit: 1,
    b:   8,
    kb:  8e3,
    mb:  8e6,
    gb:  8e9,
    tb:  8e12,
    pb:  8e15,
  })

  // IEC — bytes per unit
  wire('.iec', {
    kib: 1024,
    mib: 1024 ** 2,
    gib: 1024 ** 3,
    tib: 1024 ** 4,
  })

  document.getElementById('reset-si')!.addEventListener('click', () => {
    document.querySelectorAll<HTMLInputElement>('.num-input:not(.iec)').forEach(i => { i.value = '' })
  })
  document.getElementById('reset-iec')!.addEventListener('click', () => {
    document.querySelectorAll<HTMLInputElement>('.iec').forEach(i => { i.value = '' })
  })
</script>
